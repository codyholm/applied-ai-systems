%% Applied AI Music Recommender — system architecture (two-pipeline)
%% Source for assets/architecture.png. Render with:
%%   /Users/holmc/.npm/_npx/668c188756b835f3/node_modules/.bin/mmdc \
%%       -i assets/architecture.mmd -o assets/architecture.png \
%%       -t default -b white -w 2400
flowchart LR
    classDef llm fill:#fde68a,stroke:#b45309,stroke-width:2px,color:#1f2937
    classDef det fill:#bfdbfe,stroke:#1e40af,stroke-width:2px,color:#1f2937
    classDef store fill:#bbf7d0,stroke:#15803d,stroke-width:2px,color:#1f2937
    classDef test fill:#fbcfe8,stroke:#9d174d,stroke-width:2px,color:#1f2937
    classDef io fill:#f3f4f6,stroke:#374151,stroke-width:1px,color:#1f2937
    classDef legend fill:#ffffff,stroke:#9ca3af,stroke-width:1px,color:#1f2937

    %% =============== Top row: main data flow ===============

    INPUTS(["<b>BuildInputs</b><br/>3 question answers<br/>+ free-form description"]):::io

    subgraph BUILD ["<b>Pipeline A — build_profile</b>"]
      direction TB
      B1["<b>Validation gate</b><br/>has_minimum()<br/>raises EmptyBuildInputsError"]:::det
      B2["<b>Profile Extractor</b><br/>src/agents/profile_extractor.py<br/><i>NL → UserProfile</i><br/>(7 fields + avoid_genres)<br/>retry-once · clamping<br/>genre fallback warnings"]:::llm
      B3["<b>Critic (faithfulness)</b><br/>src/agents/critic.py<br/><i>verdict: ok | refine</i><br/>+ target shifts<br/>max 2 iters · fail-open"]:::llm
      B1 --> B2 --> B3
      B3 -- "refine" --> B3
    end

    BOUT(["<b>ProfileBuildResult</b><br/>candidate + extracted<br/>+ refinement_history<br/>+ ambiguous_match<br/>+ extractor_warnings"]):::io

    PROFILES[("<b>Profile Store</b><br/>profiles/&lt;slug&gt;.json<br/>+ 5 PRESETS (in-code)<br/><i>save / load / list<br/>delete / edit_fields</i>")]:::store

    subgraph REC ["<b>Pipeline B — recommend</b>"]
      direction TB
      R1["<b>Deterministic Scoring</b><br/>src/recommender.py<br/>7 weighted features<br/>+ avoid_genres hard-zero<br/>→ top-k"]:::det
      R2["<b>KB Retriever</b><br/>src/kb/retriever.py<br/><i>3 docs per rec</i><br/>genre + mood + song"]:::det
      R3["<b>Citation Explainer</b><br/>src/agents/explainer.py<br/><i>1 batched LLM call</i><br/>verbatim quote check<br/>fallback → mechanical"]:::llm
      R1 --> R2 --> R3
    end

    ROUT(["<b>RecommendationResult</b><br/>top-k ScoredRecommendations<br/>+ retrieved KB contexts<br/>+ grounded explanations<br/>(or mechanical fallback)"]):::io

    subgraph PRESENT ["<b>Presenters</b> — thin"]
      direction TB
      CLI["<b>src/cli.py</b><br/><i>python -m src.cli</i><br/>{build, recommend, profiles}"]:::io
      APP["<b>app.py</b><br/><i>streamlit run app.py</i><br/>4 tabs: Song Finder /<br/>Build Vibe Profile /<br/>My Profiles / Reliability"]:::io
    end

    INPUTS --> B1
    B3 -. "ok / iter cap" .-> BOUT
    BOUT -. "save_profile()<br/>(optional)" .-> PROFILES
    PROFILES -. "load" .-> R1
    BOUT -. "use directly" .-> R1
    R3 --> ROUT
    ROUT --> PRESENT
    BOUT --> PRESENT

    %% =============== Bottom row: stores feeding REC + Reliability Harness ===============

    CSV[("<b>data/songs.csv</b><br/>30 tracks · 7 dims<br/>10 genres × 3")]:::store
    KB[("<b>Knowledge Base</b><br/>src/kb/docs/<br/>10 genres + 8 moods<br/>+ 30 song notes")]:::store
    CSV -. "load" .-> R1
    KB -. "retrieve" .-> R2
    KB -. "ground" .-> R3

    subgraph EVAL ["<b>Reliability Harness</b> · src/eval/harness.py"]
      direction LR
      BCASES["<b>BUILD_CASES (5)</b><br/>4 baseline + 1 stress<br/>hand-authored<br/>expected_profile"]:::test
      RCASES["<b>RECOMMEND_CASES (5)</b><br/>preset names"]:::test
      BASSERT["<b>assert_build_<br/>neighborhood</b><br/><i>near expected_profile?</i><br/>genre + mood + numerics<br/>+ avoid_genres set"]:::test
      RASSERT["<b>assert_recommend_<br/>structural</b><br/><i>per-preset rules</i>"]:::test
      SELF["<b>LLM self-critique</b><br/><i>top-5 reflect profile?</i>"]:::llm
      SCARD["<b>Two scorecards</b><br/>+ JSON artifact<br/>--confirm gate"]:::test

      BCASES --> BASSERT --> SCARD
      RCASES --> RASSERT --> SCARD
      RCASES --> SELF --> SCARD
    end

    BCASES -. "feed each case" .-> B1
    RCASES -. "load_preset()" .-> R1

    LEGEND["<b>Legend</b><br/>🟨 LLM (all via LLMClient:<br/>Stub | Cached | Gemini gemma-4-31b-it)<br/>🟦 Deterministic / no LLM<br/>🟩 Data store / corpus<br/>🟪 Test / evaluation<br/><br/><i>Build pipeline runs rarely.<br/>Recommend pipeline runs anytime.</i>"]:::legend
